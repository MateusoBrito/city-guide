datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Tipo {
  usuario
  admin
  proprietario
}

model Cidade {
  id  Int @id @default(autoincrement())
  nome  String
  estado  String
  pais  String

  usuarios  Usuario[]
  estabelecimentos Estabelecimento[]
}

model Estabelecimento {
  id  Int  @id @default(autoincrement())
  nome  String
  categoria String
  descricao String
  imagemUrl String?

  cep String
  rua String
  bairro  String
  numero  String
  complemento  String?

  url String?
  telefone  String?

  mediaNota Float @default(0)
  numAvaliacoes  Int   @default(0)
  aprovado Boolean @default(false)
  criadoEm DateTime @default(now())

  cidadeId  Int
  cidade  Cidade @relation(fields: [cidadeId], references: [id])

  proprietarioEmail String?
  proprietario  Usuario? @relation(fields: [proprietarioEmail], references: [email])

  avaliacoes  Avaliacao[]
}

model Usuario {
  email String @id
  nome  String
  dataNascimento  DateTime
  criadoEm  DateTime @default(now())

  tipo Tipo @default(usuario)

  cidadeId  Int
  cidade  Cidade @relation(fields: [cidadeId], references: [id])

  avaliacoes  Avaliacao[]
  estabelecimentos Estabelecimento[]
}

model Avaliacao {
  usuarioEmail  String
  estabelecimentoId Int

  nota  Int
  comentario  String?

  aprovada  Boolean @default(false)

  dataAvaliacao DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioEmail], references: [email])
  estabelecimento   Estabelecimento @relation(fields: [estabelecimentoId], references: [id])

  @@id([usuarioEmail, estabelecimentoId])
}